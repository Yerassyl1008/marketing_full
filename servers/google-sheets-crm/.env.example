PORT=8010

# Вход в админку сайта — свои значения (не оставляй admin@example.com на проде).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
# Опционально: фиксированный Bearer (≥16 символов). Без него после логина выдаётся токен в памяти
# (после перезапуска CRM нужно войти снова). Нужен для Next: GET /leads?limit=1 — проверка JWT статей в админке.
# ADMIN_ACCESS_TOKEN=

# SQLITE_PATH=

# ID таблицы из URL: https://docs.google.com/spreadsheets/d/ВОТ_ЭТОТ_ID/edit
# Без ID сервер остаётся в режиме только SQLite.
GOOGLE_SHEETS_SPREADSHEET_ID=
# Имя вкладки внизу таблицы — как в Google, посимвольно (Leads или Лист1 и т.д.)
GOOGLE_SHEETS_TAB=Leads

# Из скачанного JSON ключа (IAM → Service accounts → Keys). НЕ из Google Таблицы.
# GOOGLE_SERVICE_ACCOUNT_EMAIL = поле client_email целиком.
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY = поле private_key целиком: в кавычках, с \n как в JSON (не переноси ключ на несколько строк в .env).
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nPASTE_FROM_JSON_one_line_with_backslash_n\n-----END PRIVATE KEY-----\n
# В лог и в JSON ответа добавить текст ошибки Google (для отладки)
# SHEETS_DEBUG=1

# Оформление листа при старте (списки, цвета, ширины). Отключить: SHEETS_MANAGER_FORMAT=0
# SHEETS_MANAGER_FORMAT=0

SHEETS_MIN_INTERVAL_MS=120
BOARD_CACHE_MS=2500
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=40
