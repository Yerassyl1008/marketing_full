# Скопируй в .env локально или задай те же ключи в Railway → Variables
# Для продакшена укажи ENVIRONMENT=production, свои домены в CORS_ORIGINS/ALLOWED_HOSTS

ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
ENABLE_DOCS=true
# Локально: localhost. На Render + фронт на Vercel — укажи точный origin фронта (в production нельзя *).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
#  ALLOWED_HOSTS=marketing-full-z0ke.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1
GZIP_MINIMUM_SIZE=1000
SQL_ECHO=false
BOOTSTRAP_ADMIN_ON_STARTUP=true

APP_HOST=0.0.0.0
APP_PORT=8000
WEB_CONCURRENCY=1
RUN_MIGRATIONS=true
MIGRATION_MAX_ATTEMPTS=10
MIGRATION_RETRY_INTERVAL=3

DATABASE_URL=postgresql+asyncpg://vrode:vrode_pass@db:5432/vrode

SECRET_KEY=supersecretjwtkey1234567890asdax
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password
ADMIN_NAME=Admin

# Опционально (docker-compose)
POSTGRES_USER=vrode
POSTGRES_PASSWORD=vrode_pass
POSTGRES_DB=vrode
DB_HOST=db
DB_PORT=5432
